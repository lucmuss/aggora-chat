# Docker-first contributor environment
DJANGO_ENV=development
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=dev-only-secret-key-change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:18080,http://localhost:18080

APP_NAME=Agora
APP_TAGLINE=communities first
APP_PUBLIC_URL=http://127.0.0.1:18080
APP_VERSION=0.3.10
APP_HOST_PORT=18080
POSTGRES_HOST_PORT=5432
DOCKER_APP_PUBLIC_URL=http://127.0.0.1:18080
DOCKER_DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DOCKER_DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:18080,http://localhost:18080

POSTGRES_DB=agora
POSTGRES_USER=agora
POSTGRES_PASSWORD=agora_dev
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=
DATABASE_CONN_MAX_AGE=60
DATABASE_SSL_REQUIRE=0

SEED_USERS_FILE=data/seed/users.json
SEED_ADMINS_FILE=data/seed/admins.json
SEED_COMMUNITIES_FILE=data/seed/communities.json
AUTO_MIGRATE_ON_START=1
AUTO_SEED_ON_START=1
SEED_SKIP_DEMO_CONTENT=0

CELERY_TASK_ALWAYS_EAGER=1

SEARCH_BACKEND=sql
SEARCH_INDEX_ENABLED=0
ELASTICSEARCH_URL=http://elasticsearch:9200

ACCOUNT_EMAIL_VERIFICATION=optional
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_PLACES_API_KEY=

EMAIL_DELIVERY_MODE=console
DJANGO_DEFAULT_FROM_EMAIL=noreply@example.test
COMPANY_SUPPORT_EMAIL=support@example.test
COMPANY_SUPPORT_URL=https://example.test/support

DJANGO_TIME_ZONE=Europe/Berlin
DJANGO_LANGUAGE_CODE=en-us

