# Project identity
PROJECT_NAME="aggora-chat"
PROJECT_SLUG="aggora_chat"
APP_NAME="Agora"
APP_TAGLINE="communities first"
APP_PUBLIC_URL=""
APP_VERSION="0.1.0"
SEED_USERS_FILE="data/seed/users.json"

# Runtime
DJANGO_ENV="development"
DJANGO_SETTINGS_MODULE="config.settings.dev"
DJANGO_SECRET_KEY="change-me"
DJANGO_DEBUG="true"
PORT="8000"
APP_HOST_PORT="18080"
NGINX_HOST_PORT="18086"
GUNICORN_BIND="0.0.0.0:8000"
GUNICORN_WORKERS="4"

# Django core security
DJANGO_ALLOWED_HOSTS="localhost,127.0.0.1,aggora.kolibri-kollektiv.eu"
DJANGO_CSRF_TRUSTED_ORIGINS="http://localhost:18080,https://aggora.kolibri-kollektiv.eu"
DJANGO_USE_X_FORWARDED_HOST="true"
DJANGO_SECURE_SSL_REDIRECT="false"
DJANGO_SESSION_COOKIE_SECURE="false"
DJANGO_CSRF_COOKIE_SECURE="false"
DJANGO_TIME_ZONE="Europe/Berlin"
DJANGO_LANGUAGE_CODE="en-us"
DJANGO_SITE_ID="1"
ACCOUNT_DEFAULT_HTTP_PROTOCOL="http"
ACCOUNT_EMAIL_VERIFICATION="optional"
SECURE_HSTS_SECONDS="0"
SECURE_HSTS_INCLUDE_SUBDOMAINS="false"
SECURE_HSTS_PRELOAD="false"
SECURE_REFERRER_POLICY="same-origin"

# Database
DATABASE_URL=""
POSTGRES_DB="aggora_chat"
POSTGRES_USER="aggora_chat"
POSTGRES_PASSWORD="replace_me"
POSTGRES_HOST="common-database"
POSTGRES_PORT="5432"
DATABASE_CONN_MAX_AGE="60"
DATABASE_SSL_REQUIRE="false"

# Redis / Celery / cache
REDIS_CACHE_URL="redis://redis:6379/1"
CELERY_BROKER_URL="redis://redis:6379/0"
CELERY_RESULT_BACKEND=""
CELERY_TASK_ALWAYS_EAGER="false"
SESSION_CACHE_ALIAS="default"

# Search
SEARCH_BACKEND="sql"
SEARCH_INDEX_ENABLED="0"

# Freya-compatible bootstrap accounts + seed controls
SEED_TEST_USERS_ON_START="true"
SEED_DATA_RESET_ON_START="false"
TEST_USER_EMAIL=""
TEST_USER_PASSWORD=""
TEST_USER_PHONE=""
OPS_ADMIN_EMAIL=""
OPS_ADMIN_PASSWORD=""
OPS_ADMIN_PHONE=""
OPS_MODERATOR_EMAIL=""
OPS_MODERATOR_PASSWORD=""
OPS_MODERATOR_PHONE=""
ELASTICSEARCH_URL="http://elasticsearch:9200"
ELASTICSEARCH_HOST_PORT="9200"
ES_JAVA_OPTS="-Xms512m -Xmx512m"

# Static / media
SERVE_MEDIA_FILES="true"
EMAIL_FILE_PATH="output/emails"

# OAuth / auth
GOOGLE_CLIENT_ID="replace_me"
GOOGLE_CLIENT_SECRET="replace_me"

# Email delivery
EMAIL_DELIVERY_MODE="console"
DJANGO_EMAIL_BACKEND="django.core.mail.backends.smtp.EmailBackend"
DJANGO_EMAIL_HOST="localhost"
DJANGO_EMAIL_PORT="25"
DJANGO_EMAIL_HOST_USER=""
DJANGO_EMAIL_HOST_PASSWORD=""
DJANGO_EMAIL_USE_TLS="false"
DJANGO_EMAIL_USE_SSL="false"
DJANGO_EMAIL_TIMEOUT="30"
DJANGO_DEFAULT_FROM_EMAIL="noreply@kolibri-kollektiv.eu"
DJANGO_SERVER_EMAIL="noreply@kolibri-kollektiv.eu"

# Branding / support
COMPANY_NAME="Agora"
COMPANY_SUPPORT_EMAIL="support@kolibri-kollektiv.eu"
COMPANY_SUPPORT_URL="https://aggora.kolibri-kollektiv.eu/support"

# Logging
APP_LOG_LEVEL="DEBUG"
