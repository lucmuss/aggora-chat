DJANGO_ENV=development
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=dev-only-secret-key-change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

APP_NAME=Agora
APP_TAGLINE=communities first
APP_PUBLIC_URL=http://127.0.0.1:8000
APP_VERSION=0.1.0

DATABASE_URL=
POSTGRES_DB=agora
POSTGRES_USER=agora
POSTGRES_PASSWORD=agora_dev
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_CONN_MAX_AGE=60
DATABASE_SSL_REQUIRE=0

REDIS_CACHE_URL=
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

SEARCH_BACKEND=sql
SEARCH_INDEX_ENABLED=0
ELASTICSEARCH_URL=http://elasticsearch:9200

ACCOUNT_EMAIL_VERIFICATION=optional
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

EMAIL_DELIVERY_MODE=console
DJANGO_DEFAULT_FROM_EMAIL=noreply@example.test
COMPANY_SUPPORT_EMAIL=support@example.test
COMPANY_SUPPORT_URL=https://example.test/support

DJANGO_TIME_ZONE=Europe/Berlin
DJANGO_LANGUAGE_CODE=en-us
